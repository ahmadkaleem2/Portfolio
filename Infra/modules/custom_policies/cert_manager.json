{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "route53:ChangeResourceRecordSets"
        ],
        "Resource": [
          "arn:aws:route53:::hostedzone/*"
        ]
      },
      {
        "Effect": "Allow",
        "Action": [
          "route53:ListHostedZones",
          "route53:ListResourceRecordSets",
          "route53:ListTagsForResource"
        ],
        "Resource": [
          "*"
        ]
      },
      {
        "Effect": "Allow",
        "Action": [
          "route53:ListHostedZones",
          "route53:ListResourceRecordSets",
          "route53:ListTagsForResource",
          "route53:GetChange"

        ],
        "Resource": [
          "arn:aws:route53:::change/C0594780N07F9BGPARV",
          "arn:aws:route53:::change/C06613212W650XTEJB7AX",
          "arn:aws:route53:::change/*",
          "arn:aws:route53:::change"

        ]
      }
    ]
  }